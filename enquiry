<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sweet Crumbs Bakery | Enquiry</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

    <!-- ================= HEADER ================= -->
    <header>

        <h1>Sweet Crumbs Bakery</h1>
        <p>Freshly Baked Happiness Every Day</p>

        <!-- Navigation -->
        <nav>
            <a href="index.html">Home</a>
            <a href="about.html">About Us</a>
            <a href="products.html">Products</a>
            <a href="services.html">Services</a>
            <a href="gallery.html">Gallery</a>
            <a href="enquiry.html">Enquiry</a>
            <a href="contact.html">Contact</a>
        </nav>

    </header>

    <!-- ================= MAIN CONTENT ================= -->
    <main>

        <!-- Introduction -->
        <section>

            <h2>Product Enquiry & Custom Orders</h2>

            <p>
                We'd love to help make your special occasion even sweeter.
                Complete the enquiry form below and our team will contact you
                as soon as possible.
            </p>

        </section>

        <!-- Enquiry Form -->
        <section>

            <form id="enquiryForm">

                <!-- Name -->
                <label for="name"><strong>Full Name</strong></label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="Enter your full name"
                    required>

                <!-- Email -->
                <label for="email"><strong>Email Address</strong></label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="Enter your email"
                    required>

                <!-- Phone -->
                <label for="phone"><strong>Phone Number</strong></label>
                <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="e.g. 0821234567">

                <!-- Product -->
                <label for="product"><strong>Select Product</strong></label>

                <select id="product" name="product" required>

                    <option value="">Choose a Product</option>

                    <option value="Chocolate Cake">Chocolate Cake</option>
                    <option value="Vanilla Cake">Vanilla Cake</option>
                    <option value="Wedding Cake">Wedding Cake</option>
                    <option value="Birthday Cake">Birthday Cake</option>
                    <option value="Cupcakes">Cupcakes</option>
                    <option value="Bread">Bread</option>
                    <option value="Pastries">Pastries</option>
                    <option value="Cookies">Cookies</option>
                    <option value="Catering">Catering Services</option>
                    <option value="Other">Other</option>

                </select>

                <!-- Quantity -->
                <label for="quantity"><strong>Quantity</strong></label>

                <input
                    type="number"
                    id="quantity"
                    name="quantity"
                    min="1"
                    placeholder="Enter quantity">

                <!-- Event Date -->
                <label for="date"><strong>Required Date</strong></label>

                <input
                    type="date"
                    id="date"
                    name="date">

                <!-- Message -->
                <label for="message"><strong>Message</strong></label>

                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    placeholder="Describe your order or enquiry..."
                    required></textarea>

                <!-- Newsletter -->
                <label>
                    <input type="checkbox" name="newsletter">
                    Subscribe to receive promotions and special offers.
                </label>

                <br><br>

                <!-- Buttons -->
                <button type="submit">
                    Submit Enquiry
                </button>

                <button type="reset">
                    Clear Form
                </button>

            </form>

        </section>

        <!-- Contact Information -->
        <section>

            <h2>Need Immediate Assistance?</h2>

            <p>
                📞 Phone: (011) 123-4567
            </p>

            <p>
                📧 Email: info@sweetcrumbsbakery.co.za
            </p>

            <p>
                Business Hours:
            </p>

            <ul>

                <li>Monday – Friday: 08:00 – 18:00</li>

                <li>Saturday: 08:00 – 16:00</li>

                <li>Sunday: 09:00 – 14:00</li>

            </ul>

        </section>

    </main>

    <!-- ================= FOOTER ================= -->
    <footer>

        <p><strong>Sweet Crumbs Bakery</strong></p>

        <p>Johannesburg CBD | Sandton</p>

        <p>Phone: (011) 123-4567</p>

        <p>Email: info@sweetcrumbsbakery.co.za</p>

        <p>Follow us on Facebook | Instagram | WhatsApp</p>

        <p>&copy; 2026 Sweet Crumbs Bakery. All Rights Reserved.</p>

    </footer>

    <!-- JavaScript -->
    <script src="js/script.js"></script>

</body>

</html>